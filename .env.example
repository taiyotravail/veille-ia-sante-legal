# =============================================================================
# Configuration — à copier dans un fichier .env local (NE JAMAIS committer .env)
# =============================================================================
# Pipeline 100% open source : aucune clé API requise.
#   - Recherche web : DuckDuckGo (ddgs)
#   - Scraping       : trafilatura
#   - LLM            : Ollama local

# =============================================================================
# Configuration Ollama Local — zéro coût, confidentialité garantie
# =============================================================================
# Modèle Ollama local (doit supporter le tool calling, ex: qwen2.5:3b)
# OLLAMA_MODEL=qwen2.5:3b

# Base URL Ollama (par défaut: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Langue pour Presidio (anonymisation locale)
# PRESIDIO_LANG=fr

# Troncature préventive (maîtrise du budget de tokens du modèle local)
# MAX_CHARS_PER_PAGE=20000
