# =============================================================================
# Clés API — à copier dans un fichier .env local (NE JAMAIS committer .env)
# =============================================================================

# Anthropic — fournisseur LLM exclusif du projet
ANTHROPIC_API_KEY=sk-ant-...

# Firecrawl — scraping anti-bot en Markdown propre
FIRECRAWL_API_KEY=fc-...

# Tavily — recherche web pour le Chercheur de niche
TAVILY_API_KEY=tvly-...

# -----------------------------------------------------------------------------
# Paramètres optionnels (valeurs par défaut dans src/config.py)
# -----------------------------------------------------------------------------
# ANTHROPIC_MODEL=claude-sonnet-4-6
# PRESIDIO_LANG=fr
# MAX_CHARS_PER_PAGE=40000
